# data-gov-il-mcp Configuration

# Transport & Server Settings
TRANSPORT=stdio
PORT=3664
HOST=0.0.0.0
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# API Configuration
CKAN_BASE_URL=https://data.gov.il/api/3/action
CKAN_TIMEOUT_MS=10000
CKAN_SEARCH_TIMEOUT_MS=15000

# Caching
CACHE_TTL_MS=300000
CACHE_MAX_ITEMS=500

# Rate Limiting (development defaults)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Authentication (default: none)
# Set to: none, apikey, or oauth
AUTH_MODE=none

# Optional Features
MCP_ENABLE_ELICITATION=false
MCP_ENABLE_SAMPLING=false
